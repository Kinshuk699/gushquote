# Copy this file to .env and fill in values.
# GushQuote runs WITHOUT any keys (deterministic fallback extraction).
# For the polished demo, add ONE key below. DeepSeek is preferred if both are set.

# --- Option A: DeepSeek (recommended — cheap, text-only, OpenAI-compatible) ---
# Get a key at https://platform.deepseek.com -> API keys
DEEPSEEK_API_KEY=
# Optional overrides (defaults shown):
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# GUSHQUOTE_MODEL=deepseek-chat

# --- Option B: OpenAI (used only if DEEPSEEK_API_KEY is empty) ---
OPENAI_API_KEY=
# GUSHQUOTE_MODEL=gpt-4o-mini
